{
  "openapi": "3.0.0",
  "info": {
    "title": "Web3GPT Skill API",
    "description": "Simple agent-first chat API for Web3GPT. Start a chat with no params, then continue with the returned chatId.",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "/api",
      "description": "Web3GPT API"
    }
  ],
  "components": {
    "schemas": {
      "SkillRequest": {
        "type": "object",
        "properties": {
          "agentId": {
            "type": "string",
            "description": "Optional agent ID. Defaults to the Web3GPT agent."
          },
          "chatId": {
            "type": "string",
            "description": "Optional chat ID. If omitted, a new chat is created."
          },
          "message": {
            "type": "string",
            "description": "Optional message to send to the agent."
          },
          "history": {
            "type": "boolean",
            "description": "Return full simplified history when true.",
            "default": false
          },
          "full": {
            "type": "boolean",
            "description": "Alias for history=true.",
            "default": false
          }
        }
      },
      "SkillHistoryItem": {
        "type": "object",
        "required": ["id", "role", "text"],
        "properties": {
          "id": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": ["user", "assistant", "system"]
          },
          "text": {
            "type": "string"
          }
        }
      },
      "SkillResponse": {
        "type": "object",
        "required": ["agentId", "chatId", "response"],
        "properties": {
          "agentId": {
            "type": "string"
          },
          "chatId": {
            "type": "string",
            "description": "Persist this value and pass it back on subsequent calls."
          },
          "response": {
            "type": "string",
            "nullable": true,
            "description": "Latest assistant response. Null when a chat is created without sending a message."
          },
          "history": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SkillHistoryItem"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "agentId": {
            "type": "string"
          },
          "chatId": {
            "type": "string"
          },
          "error": {
            "type": "string"
          }
        }
      }
    }
  },
  "paths": {
    "/skill": {
      "get": {
        "summary": "Start or inspect a skill chat",
        "description": "Call with no parameters to create a new chat and receive a chatId. Pass chatId to inspect an existing chat. Add history=true or full=true to receive the full simplified message history.",
        "parameters": [
          {
            "name": "agentId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "chatId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "message",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Optional message to send. Use POST for larger prompts."
          },
          {
            "name": "history",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "full",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "Alias for history=true."
          }
        ],
        "responses": {
          "200": {
            "description": "Skill chat response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SkillResponse"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Continue a skill chat",
        "description": "Send a message to the agent. If chatId is omitted, a new chat is created automatically. The response always includes the chatId so you can keep using the same thread.",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SkillRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Skill chat response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SkillResponse"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "options": {
        "summary": "CORS preflight",
        "responses": {
          "200": {
            "description": "CORS headers"
          }
        }
      }
    }
  }
}
